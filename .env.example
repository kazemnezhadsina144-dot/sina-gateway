PORT=4173
NODE_ENV=development
TEST_MODE=false

# Live Supabase capture.
# Paste only the public Project URL and anon key.
# Never paste the service_role key here.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Production hardening.
ALLOWED_ORIGINS=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=12
MAX_BODY_BYTES=32000

# Optional Cloudflare Turnstile.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Telegram ops bot (same as SourceA / Noetfield — no webhooks).
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=
